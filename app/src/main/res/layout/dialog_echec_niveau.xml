<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_echec">

    <!-- Logo Échec -->
    <ImageView
        android:id="@+id/imgEchec"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_echec"
        android:layout_marginBottom="16dp"
        android:contentDescription="Échec" />

    <!-- Titre -->
    <TextView
        android:id="@+id/tvTitreEchec"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Niveau Échoué !"
        android:textSize="24sp"
        android:textColor="#FF5252"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvMessageEchec"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Votre score est insuffisant"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Détails du score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_score_card"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOTRE SCORE"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvScoreObtenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5/10"
                android:textSize="28sp"
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#DDDDDD"
            android:layout_marginHorizontal="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINIMUM"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvScoreMinimum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7/10"
                android:textSize="28sp"
                android:textColor="#58CC02"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Icône encouragement -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💪"
        android:textSize="40sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message encouragement -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="N'abandonnez pas ! Réessayez !"
        android:textSize="14sp"
        android:textColor="#58CC02"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Bouton Refaire -->
    <Button
        android:id="@+id/btnRefaireNiveau"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🔄 REFAIRE LE NIVEAU"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="12dp" />

    <!-- Bouton Quitter -->
    <Button
        android:id="@+id/btnQuitterNiveau"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🏠 Retour aux langues"
        android:textColor="#666666"
        android:textSize="14sp"
        android:backgroundTint="#F5F5F5" />

</LinearLayout>