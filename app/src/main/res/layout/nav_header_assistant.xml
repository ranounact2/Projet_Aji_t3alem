<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤖 Assistant IA"
        android:textSize="22sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#F5F5F5" />

    <!-- Question actuelle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ta question apparaîtra ici"
        android:textSize="14sp"
        android:textColor="#666666"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:background="#FFF9C4"
        android:id="@+id/tvAiQuestion" />

    <!-- Loader -->
    <ProgressBar
        android:id="@+id/aiProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="gone" />

    <!-- Réponse AI -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuie sur le bouton pour demander de l'aide"
            android:textSize="15sp"
            android:textColor="#333333"
            android:padding="12dp"
            android:background="#E8F5E9"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <!-- Bouton Demander -->
    <Button
        android:id="@+id/btnAskAI"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="🤖 DEMANDER DE L'AIDE"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#58CC02"
        android:layout_marginTop="16dp" />

</LinearLayout>