<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Contenu principal -->
    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Barre supérieure -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="24sp"
                android:textColor="#58CC02"
                android:gravity="center"
                android:clickable="true"
                android:onClick="finish" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quiz"
                android:textSize="20sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- ✅ Caméra miniature à côté de l'assistant -->
            <androidx.camera.view.PreviewView
                android:id="@+id/cameraPreviewView"
                android:layout_width="50dp"
                android:layout_height="65dp"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"
                android:background="@drawable/cadre_camera_mini" />

            <TextView
                android:id="@+id/btnOpenAssistant"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="🤖"
                android:textSize="24sp"
                android:gravity="center"
                android:clickable="true" />
        </LinearLayout>

        <!-- Barre de progression -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="#E0E0E0"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <View
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="#58CC02" />
        </LinearLayout>

        <!-- Numéro question -->
        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 0/0"
            android:textSize="12sp"
            android:textColor="#58CC02"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Texte question -->
        <TextView
            android:id="@+id/tvQuestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="20sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Container options -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/optionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- Bouton Valider -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnValidate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="VALIDER"
            android:textColor="#58CC02"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_green_rounded"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Drawer Assistant IA -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:headerLayout="@layout/nav_header_assistant"
        android:background="#FFFFFF" />

</androidx.drawerlayout.widget.DrawerLayout>